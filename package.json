{
  "name": "softcurse-hex",
  "version": "1.0.0",
  "description": "Softcurse H.E.X. — Intelligent Cyberpunk Desktop Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "rebuild": "node scripts/rebuild.js"
  },
  "dependencies": {
    "node-schedule": "^2.1.1",
    "sherpa-onnx": "^1.10.30",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.softcurse.hex",
    "productName": "Softcurse H.E.X.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "local-voice/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    }
  }
}
