{
  "name": "softcurse-hex",
  "version": "1.1.0",
  "description": "Softcurse HEX - The Quiet Cardinal desktop companion",
  "author": "Softcurse Lab",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/build.js",
    "rebuild": "node scripts/rebuild.js",
    "postinstall": "electron-builder install-app-deps",
    "cf:dev": "npx wrangler dev cloudflare/hex-server/src/index.js --config cloudflare/hex-server/wrangler.jsonc",
    "cf:deploy": "npx wrangler deploy --config cloudflare/hex-server/wrangler.jsonc",
    "llama:qwen": "powershell -ExecutionPolicy Bypass -File scripts/llamacpp/start-qwen3.ps1",
    "test:capabilities": "node scripts/verify-hunter-capabilities-contract.mjs",
    "test:desktop-capabilities": "node scripts/verify-desktop-provider-capabilities-contract.cjs",
    "test:live-keys": "node scripts/verify-live-keys-capability-resilience.cjs",
    "test:provider-queue": "node scripts/verify-ai-provider-queue-guard.cjs",
    "test:context-packet": "node scripts/verify-context-packet-v2-contract.mjs",
    "test:cloud-rehydrate": "node scripts/verify-cloud-context-rehydrator.cjs",
    "test:voice-wake": "node scripts/verify-voice-wake-routing.cjs",
    "test:voice-direct": "node scripts/verify-direct-voice-commands.cjs",
    "test:contracts": "npm run test:voice-wake && npm run test:voice-direct && npm run test:capabilities && npm run test:desktop-capabilities && npm run test:live-keys && npm run test:provider-queue && npm run test:context-packet && npm run test:context-priority && npm run test:cloud-rehydrate && npm run test:action-outcomes && npm run test:prompt-actions && npm run test:brain-recovery && npm run test:brain-telemetry && npm run test:brain-action-recovery && npm run test:brain-evolution && npm run test:finetune-export && npm run test:ai-routed-actions && npm run test:ai-provider-action-recovery && npm run test:performance-policy && npm run test:cloud-lite-cache && npm run test:cloud-degraded-fallback && npm run test:cloud-token && npm run test:cloud-access-token && npm run test:config-save-secrets && npm run test:cloud-token-vault && npm run test:performance-settings",
    "test:action-outcomes": "node scripts/verify-action-outcome-recorder.cjs",
    "test:prompt-actions": "node scripts/verify-prompt-action-outcomes.cjs",
    "test:brain-recovery": "node scripts/verify-brain-router-action-recovery.cjs",
    "test:brain-telemetry": "node scripts/verify-brain-telemetry-priority.cjs",
    "test:ai-routed-actions": "node scripts/verify-ai-routed-actions.cjs",
    "test:performance-policy": "node scripts/verify-performance-policy.cjs",
    "test:cloud-lite-cache": "node scripts/verify-cloud-context-lite-cache.cjs",
    "test:cloud-token": "node scripts/verify-cloud-token-preservation.cjs",
    "test:cloud-access-token": "node scripts/verify-cloud-access-token-save.cjs",
    "test:config-save-secrets": "node scripts/verify-config-save-preserves-secrets.cjs",
    "test:performance-settings": "node scripts/verify-performance-settings.cjs",
    "test:cloud-token-vault": "node scripts/verify-cloud-token-vault-fallback.cjs",
    "test:context-priority": "node scripts/verify-context-priority-references.mjs",
    "test:cloud-degraded-fallback": "node scripts/verify-cloud-degraded-fallback.cjs",
    "test:brain-action-recovery": "node scripts/verify-brain-action-provider-recovery.cjs",
    "test:brain-evolution": "node scripts/verify-brain-evolution-recorder.cjs",
    "test:finetune-export": "node scripts/verify-finetune-exporter.cjs",
    "test:ai-provider-action-recovery": "node scripts/verify-ai-provider-failure-action-recovery.cjs"
  },
  "dependencies": {
    "node-schedule": "^2.1.1",
    "playwright-core": "^1.59.1",
    "sherpa-onnx": "^1.10.30",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.softcurse.hex",
    "productName": "Softcurse H.E.X.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "ai/**/*",
      "plugins/**/*",
      "local-voice/**/*",
      "!local-voice/models",
      "!local-voice/models/**/*",
      "scripts/**/*",
      "!src/assets/cardinal/**/*",
      "!src/css/cardinal-theme.css"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/hex.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/hex.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/hex.png"
    }
  }
}
